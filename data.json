<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>我的優惠</title>
    
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="我的優惠">
    <meta name="mobile-web-app-capable" content="yes">
    
    <link rel="manifest" href="data:application/json;base64,ewogICJuYW1lIjogIuaIkeeahOYSquWgqyIsCiAgInNob3J0X25hbWUiIjogIuaIkeeahOYSquWgqyIsCiAgInN0YXJ0X3VybCI6ICIuIiwKICAiZGlzcGxheSI6ICJzdGFuZGFsb25lIiwKICAiYmFja2dyb3VuZF9jb2xvciI6ICIjRkY3RjAwIiwKICAidGhlbWVfY29sb3IiOiAiIzI1NjNDRSIsCiAgIm9yaWVudGF0aW9uIjogInBvcnRyYWl0Igp9">

    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        /* 隱藏捲軸並優化手機滑動體驗 */
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        body { -webkit-tap-highlight-color: transparent; }
    </style>
</head>
<body class="bg-gray-100 font-sans h-screen flex flex-col max-w-md mx-auto shadow-2xl relative bg-white pb-safe">

    <header class="bg-blue-600 text-white px-4 py-3 flex justify-between items-center sticky top-0 z-50 shadow-md pt-6">
        <h1 class="text-xl font-bold tracking-wider">我的優惠</h1>
        <div class="relative">
            <select id="monthSelect" onchange="renderActiveTab()" class="bg-white text-gray-800 text-sm font-semibold rounded-lg px-3 py-1.5 pr-8 appearance-none cursor-pointer border border-gray-200 focus:outline-none shadow-sm">
                <option value="1">1 月</option>
                <option value="2">2 月</option>
                <option value="3">3 月</option>
                <option value="4">4 月</option>
                <option value="5">5 月</option>
                <option value="6" selected>6 月</option>
                <option value="7">7 月</option>
                <option value="8">8 月</option>
                <option value="9">9 月</option>
                <option value="10">10 月</option>
                <option value="11">11 月</option>
                <option value="12">12 月</option>
            </select>
            <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-gray-600">
                <i class="fas fa-chevron-down text-xs"></i>
            </div>
        </div>
    </header>

    <main class="flex-1 overflow-y-auto p-4 pb-24 no-scrollbar">
        <div id="dynamic-content" class="space-y-4">
            <div class="text-center py-12 text-gray-400">
                <i class="fas fa-spinner fa-spin text-3xl mb-2"></i>
                <p>優惠資訊即時載入中...</p>
            </div>
        </div>
    </main>

    <nav class="bg-white border-t border-gray-200 fixed bottom-0 left-0 right-0 max-w-md mx-auto flex justify-around py-3 shadow-lg z-50 px-2">
        <button onclick="switchTab('food')" id="tab-food" class="tab-btn flex flex-col items-center space-y-1 text-blue-600 font-semibold flex-1">
            <i class="fas fa-utensils text-lg"></i>
            <span class="text-xs">美食</span>
        </button>
        <button onclick="switchTab('life')" id="tab-life" class="tab-btn flex flex-col items-center space-y-1 text-gray-400 hover:text-gray-600 flex-1">
            <i class="fas fa-shopping-bag text-lg"></i>
            <span class="text-xs">生活</span>
        </button>
        <button onclick="switchTab('travel')" id="tab-travel" class="tab-btn flex flex-col items-center space-y-1 text-gray-400 hover:text-gray-600 flex-1">
            <i class="fas fa-plane text-lg"></i>
            <span class="text-xs">航空旅遊</span>
        </button>
        <button onclick="switchTab('credit')" id="tab-credit" class="tab-btn flex flex-col items-center space-y-1 text-gray-400 hover:text-gray-600 flex-1">
            <i class="fas fa-credit-card text-lg"></i>
            <span class="text-xs">信用卡</span>
        </button>
    </nav>

    <script>
        // 帶入你提供的 GitHub Raw 網址
        const GITHUB_RAW_URL = 'https://raw.githubusercontent.com/gn1884728/my-travels/refs/heads/main/data.json';
        
        let globalData = null;
        let currentTab = 'food';

        // 從 GitHub 異步取得最新的 JSON 資料
        async function fetchGitHubData() {
            try {
                // 加入時間戳記參數防止瀏覽器快取舊資料
                const response = await fetch(`${GITHUB_RAW_URL}?t=${new Date().getTime()}`);
                globalData = await response.json();
                renderActiveTab();
            } catch (error) {
                console.error("GitHub 資料加載失敗:", error);
                document.getElementById('dynamic-content').innerHTML = `
                    <div class="text-center py-12 text-red-500">
                        <i class="fas fa-exclamation-triangle text-3xl mb-2"></i>
                        <p>連線失敗，請檢查網路或 GitHub 檔案</p>
                    </div>`;
            }
        }

        // 將資料渲染成精美卡片的優化邏輯
        function renderActiveTab() {
            if (!globalData) return;

            const selectedMonth = document.getElementById('monthSelect').value;
            const container = document.getElementById('dynamic-content');
            
            // 安全防護：若該月份或分類不存在資料，顯示提示畫面
            if (!globalData[selectedMonth] || !globalData[selectedMonth][currentTab] || globalData[selectedMonth][currentTab].length === 0) {
                container.innerHTML = `
                    <div class="text-center py-16 text-gray-400">
                        <i class="far fa-folder-open text-4xl mb-3"></i>
                        <p class="text-sm">${selectedMonth} 月份暫無相關優惠資訊</p>
                    </div>`;
                return;
            }

            const items = globalData[selectedMonth][currentTab];
            let htmlContent = '';

            // 尋訪陣列並生成卡片
            items.forEach(item => {
                // 根據發卡組織給予專屬的顏色標籤
                let badgeColor = 'bg-gray-600';
                if (item.brand.toUpperCase() === 'JCB') badgeColor = 'bg-red-500';
                if (item.brand.toUpperCase() === 'VISA') badgeColor = 'bg-blue-800';
                if (item.brand.toUpperCase() === 'AMEX' || item.brand.toUpperCase() === '美國運通') badgeColor = 'bg-cyan-600';

                htmlContent += `
                    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden active:scale-[0.99] transition-transform duration-100">
                        <div class="p-4">
                            <div class="flex justify-between items-start mb-2.5">
                                <span class="${badgeColor} text-white text-[11px] font-black tracking-wider px-2 py-0.5 rounded">${item.brand}</span>
                                <span class="text-xs font-semibold text-blue-600 bg-blue-50 px-2 py-0.5 rounded-full"><i class="far fa-clock mr-1"></i>${item.time}</span>
                            </div>
                            <h3 class="font-bold text-gray-900 text-base mb-1">${item.title}</h3>
                            <p class="text-gray-500 text-xs mb-4 leading-relaxed">${item.desc}</p>
                            <a href="${item.url}" target="_blank" class="w-full inline-flex justify-center items-center bg-gray-50 hover:bg-blue-50 active:bg-blue-100 text-blue-600 font-bold text-xs py-2.5 px-4 rounded-xl border border-gray-200 transition-colors">
                                前往活動官方網頁 <i class="fas fa-external-link-alt ml-1.5 text-[10px]"></i>
                            </a>
                        </div>
                    </div>`;
            });

            container.innerHTML = htmlContent;
        }

        // 下方 Tab 切換與視覺反饋
        function switchTab(tabName) {
            currentTab = tabName;
            
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.classList.remove('text-blue-600', 'font-semibold');
                btn.classList.add('text-gray-400');
            });
            const activeBtn = document.getElementById(`tab-${tabName}`);
            activeBtn.classList.add('text-blue-600', 'font-semibold');
            activeBtn.classList.remove('text-gray-400');

            renderActiveTab();
        }

        // 初始化載入
        fetchGitHubData();
    </script>
</body>
</html>
